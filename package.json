{
  "name": "@williamphelps13/ui",
  "version": "0.0.0",
  "description": "React component library",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "tokens": "node style-dictionary.config.mjs",
    "css": "tailwindcss -i src/styles/index.css -o dist/styles.css",
    "build": "pnpm tokens && tsdown && pnpm css",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "knip": "knip",
    "spell": "cspell \"README.md\" \"src/**/*.{ts,tsx,md}\"",
    "assert:use-client": "node scripts/assert-use-client.mjs",
    "verify:pack": "publint",
    "verify:types": "attw --pack"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=11"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@babel/core": "^7.29.0",
    "@changesets/cli": "^2.31.0",
    "@eslint-react/eslint-plugin": "^5.8.4",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/cli": "^4.3.0",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.7.0",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "react": "catalog:",
    "react-dom": "catalog:",
    "style-dictionary": "^5.4.1",
    "tailwindcss": "catalog:",
    "tsdown": "^0.22.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.4"
  }
}
