{
  "name": "@williamphelps13/ui",
  "version": "0.0.0",
  "description": "React component library",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "tokens": "node style-dictionary.config.mjs",
    "build": "pnpm tokens && tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "knip": "knip",
    "assert:use-client": "node scripts/assert-use-client.mjs",
    "verify:pack": "publint",
    "verify:types": "attw --pack"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=11"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "^0.22.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.4"
  }
}
