{
  "name": "@williamphelps13/ui",
  "version": "0.0.0",
  "description": "React component library",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "tokens": "node style-dictionary.config.mjs",
    "css": "tailwindcss -i src/styles/index.css -o dist/styles.css",
    "build": "pnpm tokens && tsdown --tsconfig tsconfig.build.json && pnpm css",
    "typecheck": "tsc --noEmit -p tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "knip": "knip",
    "spell": "cspell \"README.md\" \"src/**/*.{ts,tsx,md}\"",
    "assert:use-client": "node scripts/assert-use-client.mjs",
    "verify:pack": "publint",
    "verify:types": "attw --pack",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --config-file chromatic.config.json"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@babel/core": "^7.29.7",
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint-react/eslint-plugin": "^5.8.10",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^17.2.0",
    "cspell": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "jiti": "^2.7.0",
    "knip": "^6.15.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "^10.4.1",
    "style-dictionary": "^5.4.2",
    "tailwindcss": "catalog:",
    "tsdown": "^0.22.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
